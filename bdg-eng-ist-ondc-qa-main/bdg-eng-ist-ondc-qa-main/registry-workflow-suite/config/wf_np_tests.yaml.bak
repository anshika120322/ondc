          key:
            uk_id: "wfnp05_key"
            signing_public_key: "MCowBQYDK2VwAyEA1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0005=="
            encryption_public_key: "MCowBQYDK2VwAyEA9876543210ZYXWVUTSRQPONMLKJIHGFEDCBAzyxwvutsrqponmlkjihgfedcba0005=="
            signed_algorithm: "ED25519"
            encryption_algorithm: "X25519"
            valid_from: "2026-01-01T00:00:00.000Z"
            valid_until: "2027-01-01T00:00:00.000Z"
          location:
            location_id: "loc_wfnp05"
            country: "IND"
            city: ["std:080"]
            type: "SERVICEABLE"
          uri:
            uri_id: "uri_wfnp05"
            type: "CALLBACK"
            url: "https://{{subscriber_id}}/ondc/callback"
          configs:
            - domain: "ONDC:RET1A"
              np_type: "BPP"
