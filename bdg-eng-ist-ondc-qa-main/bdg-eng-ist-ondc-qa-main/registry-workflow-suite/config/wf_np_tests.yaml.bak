  # ===========================================================================
  # WF-NP-09 · New Seller App (BPP) Registration — Multi-Domain, Multi-City
  # ===========================================================================
  - id: "WF-NP-09"
    name: "New Seller App (BPP) Registration — Multi-Domain, Multi-City"
    description: >
      A BPP serving multiple ONDC domains (ONDC:RET10 Grocery and ONDC:RET16
      Health & Wellness) across multiple cities registers all domain-city
      combinations in a single subscribe call, then verifies Gateway broadcast
      coverage for each combination.
      Mirrors WF-NP-09 from registry-workflows.md.
    workflow: true
    steps:
      - name: "Step 1 – Admin whitelists BPP for all domains and cities"
        method: "POST"
        endpoint: "/admin/subscribe"
        auth_type: "admin"
        data:
          dns_skip: true
          skip_ssl_verification: true
          participant_id: "{{subscriber_id}}"
          action: "WHITELISTED"
          configs:
            - domain: "ONDC:RET10"
              np_type: "BPP"
              subscriber_id: "{{subscriber_id}}"
            - domain: "ONDC:RET16"
              np_type: "BPP"
              subscriber_id: "{{subscriber_id}}"
        expected_status: 200
        validate:
          - field: "message.ack.status"
            value: "ACK"

