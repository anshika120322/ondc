        allow_failure: true

      - name: "Step 2 – NP PATCH V3 subscribe with new configs block"
        method: "PATCH"
        endpoint: "/v3.0/subscribe"
        auth_type: "v3"
        data:
          participant_id: "{{subscriber_id}}"
          configs:
            - domain: "ONDC:LOG"
              np_type: "BPP"
              subscriber_id: "{{subscriber_id}}"
